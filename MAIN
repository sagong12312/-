<script>
// ═══════════ 한글 태그 매핑 ═══════════
const TAGS = {
  // 제목/문단
  '큰제목':{tag:'h1',cat:'제목/문단'},
  '제목':{tag:'h2',cat:'제목/문단'},
  '중제목':{tag:'h3',cat:'제목/문단'},
  '소제목':{tag:'h4',cat:'제목/문단'},
  '문단':{tag:'p',cat:'제목/문단'},
  '글':{tag:'p',cat:'제목/문단'},
  '줄바꿈':{tag:'br',self:true,cat:'제목/문단'},
  '구분선':{tag:'hr',self:true,cat:'제목/문단'},
  '인용':{tag:'blockquote',cat:'제목/문단'},
  // 꾸미기
  '굵게':{tag:'strong',cat:'꾸미기'},
  '기울임':{tag:'em',cat:'꾸미기'},
  '밑줄':{tag:'u',cat:'꾸미기'},
  '취소선':{tag:'s',cat:'꾸미기'},
  '강조':{tag:'mark',cat:'꾸미기'},
  '작게':{tag:'small',cat:'꾸미기'},
  '코드':{tag:'code',cat:'꾸미기'},
  '위첨자':{tag:'sup',cat:'꾸미기'},
  '아래첨자':{tag:'sub',cat:'꾸미기'},
  // 링크/이미지/버튼
  '링크':{tag:'a',cat:'링크/이미지/버튼',attrMap:{'주소':'href','대상':'target'}},
  '이미지':{tag:'img',self:true,cat:'링크/이미지/버튼',attrMap:{'주소':'src','설명':'alt','너비':'width','높이':'height'},content2:'alt'},
  '버튼':{tag:'button',cat:'링크/이미지/버튼'},
  // 목록/표
  '목록':{tag:'ul',cat:'목록/표'},
  '순서목록':{tag:'ol',cat:'목록/표'},
  '항목':{tag:'li',cat:'목록/표'},
  '표':{tag:'table',cat:'목록/표'},
  '행':{tag:'tr',cat:'목록/표'},
  '칸':{tag:'td',cat:'목록/표'},
  '머리칸':{tag:'th',cat:'목록/표'},
  // 구조
  '구역':{tag:'div',cat:'구조'},
  '범위':{tag:'span',cat:'구조'},
  '구획':{tag:'section',cat:'구조'},
  '머리말':{tag:'header',cat:'구조'},
  '꼬리말':{tag:'footer',cat:'구조'},
  // 입력
  '입력칸':{tag:'input',self:true,cat:'입력',attrMap:{'종류':'type','안내':'placeholder','값':'value'}},
  '여러줄입력':{tag:'textarea',cat:'입력',attrMap:{'안내':'placeholder'}},
};

// 공통 속성: 색상/배경/크기/정렬
const STYLE_ATTRS = {
  '색':'color','글자색':'color','배경':'background','배경색':'background',
  '크기':'font-size','글자크기':'font-size','정렬':'text-align',
  '굵기':'font-weight','여백':'padding','바깥여백':'margin',
  '둥글기':'border-radius','테두리':'border','너비':'width','높이':'height'
};
// 색상 한글 → 영문
const COLORS={'빨강':'red','파랑':'blue','초록':'green','노랑':'yellow','검정':'black','하양':'white','회색':'gray','주황':'orange','보라':'purple','분홍':'pink','하늘':'skyblue','남색':'navy','갈색':'brown'};
const ALIGN={'왼쪽':'left','가운데':'center','오른쪽':'right','양쪽':'justify'};

function transpileLine(raw){
  const line=raw.replace(/\t/g,'  ');
  const indent=line.match(/^\s*/)[0];
  let s=line.trim();
  if(!s)return {html:'',indent};
  if(s.startsWith('//')||s.startsWith('주석:'))return {html:'',indent,skip:true};

  // <태그>내용 또는 <태그[속성=값]>내용
  const m=s.match(/^<([^>\[]+)(\[[^\]]*\])*>(.*)$/);
  if(!m){
    // 태그 없으면 그냥 텍스트
    return {html:indent+escapeHtml(s),indent};
  }
  const tagKo=m[1].trim();
  const attrsRaw=s.match(/\[([^\]]*)\]/g)||[];
  let content=m[3];

  const def=TAGS[tagKo];
  if(!def){
    return {html:indent+'<!-- 알 수 없는 태그: '+escapeHtml(tagKo)+' -->',indent,unknown:tagKo};
  }

  // 속성 파싱
  let attrs='',styles='';
  attrsRaw.forEach(a=>{
    const inner=a.slice(1,-1);
    const eq=inner.indexOf('=');
    if(eq<0)return;
    const k=inner.slice(0,eq).trim();
    let v=inner.slice(eq+1).trim();
    // 태그 전용 속성
    if(def.attrMap&&def.attrMap[k]){
      attrs+=` ${def.attrMap[k]}="${escapeAttr(v)}"`;
    }
    // 스타일 속성
    else if(STYLE_ATTRS[k]){
      let cssV=v;
      if(STYLE_ATTRS[k]==='color'||STYLE_ATTRS[k]==='background')cssV=COLORS[v]||v;
      if(STYLE_ATTRS[k]==='text-align')cssV=ALIGN[v]||v;
      if(STYLE_ATTRS[k]==='font-size'&&/^\d+$/.test(v))cssV=v+'px';
      if((STYLE_ATTRS[k]==='padding'||STYLE_ATTRS[k]==='margin'||STYLE_ATTRS[k]==='border-radius'||STYLE_ATTRS[k]==='width'||STYLE_ATTRS[k]==='height')&&/^\d+$/.test(v))cssV=v+'px';
      if(STYLE_ATTRS[k]==='font-weight'&&v==='굵게')cssV='bold';
      styles+=`${STYLE_ATTRS[k]}:${cssV};`;
    }
    // 기타 속성 그대로
    else{attrs+=` ${k}="${escapeAttr(v)}"`;}
  });
  if(styles)attrs+=` style="${styles}"`;

  // self-closing 태그
  if(def.self){
    return {html:indent+`<${def.tag}${attrs}>`,indent};
  }
  // 일반 태그
  const inner=transpileInline(content);
  return {html:indent+`<${def.tag}${attrs}>${inner}</${def.tag}>`,indent};
}

// 인라인 한글 태그 변환 (문단 안의 *굵게* 같은 것)
function transpileInline(text){
  let t=escapeHtml(text);
  // **굵게**
  t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>');
  // *기울임*
  t=t.replace(/\*([^*]+)\*/g,'<em>$1</em>');
  // __밑줄__
  t=t.replace(/__([^_]+)__/g,'<u>$1</u>');
  return t;
}

function escapeHtml(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function escapeAttr(s){return String(s).replace(/"/g,'&quot;');}

function transpile(src){
  const lines=src.split('\n');
  const out=[];
  lines.forEach(l=>{
    const r=transpileLine(l);
    if(r.skip)return;
    if(r.html!=='')out.push(r.html);
  });
  return out.join('\n');
}

// ═══════════ UI ═══════════
const input=document.getElementById('input');
const output=document.getElementById('output');
const preview=document.getElementById('preview');

function update(){
  const src=input.value;
  const html=transpile(src);
  output.textContent=html||'(변환된 HTML이 여기 표시됩니다)';
  const doc=`<!DOCTYPE html><html><head><meta charset="UTF-8"><style>body{font-family:-apple-system,sans-serif;padding:16px;line-height:1.6}img{max-width:100%}</style></head><body>${html}</body></html>`;
  preview.srcdoc=doc;
  document.getElementById('lines').textContent=src.split('\n').filter(l=>l.trim()).length;
  document.getElementById('stat').textContent=html?'변환 완료':'대기 중';
}
input.addEventListener('input',update);
// 탭키 처리
input.addEventListener('keydown',e=>{
  if(e.key==='Tab'){e.preventDefault();const s=input.selectionStart,en=input.selectionEnd;input.value=input.value.slice(0,s)+'  '+input.value.slice(en);input.selectionStart=input.selectionEnd=s+2;update();}
});

function copyCode(){
  const html=transpile(input.value);
  navigator.clipboard.writeText(html).then(()=>toast('HTML이 복사되었습니다!'));
}
function downloadHtml(){
  const html=transpile(input.value);
  const full=`<!DOCTYPE html>\n<html lang="ko">\n<head>\n<meta charset="UTF-8">\n<meta name="viewport" content="width=device-width, initial-scale=1.0">\n<title>문서</title>\n</head>\n<body>\n${html}\n</body>\n</html>`;
  const blob=new Blob([full],{type:'text/html'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='문서.html';a.click();
  toast('HTML 파일이 저장되었습니다!');
}
function loadExample(){
  input.value=`<큰제목[색=파랑][정렬=가운데]>한글HTML 변환기
<구분선>
<제목>소개
<문단>이것은 **한글 태그**로 작성한 *문서*입니다.
<문단[배경=하늘][여백=12][둥글기=8]>속성도 한글로 지정할 수 있어요.

<중제목>좋아하는 음식
<목록>
<항목>김치찌개
<항목>비빔밥
<항목>떡볶이

<중제목>링크와 버튼
<링크[주소=https://github.com]>깃허브 가기
<줄바꿈>
<버튼[배경=초록][색=하양][여백=10][둥글기=6]>눌러보세요

<인용[색=회색]>한글로 코딩하니 편리하네요!`;
  update();
}

function openHelp(){
  buildTagList();
  document.getElementById('help').classList.add('open');
}
function closeHelp(){document.getElementById('help').classList.remove('open');}
function buildTagList(){
  const cats={};
  for(const[ko,def]of Object.entries(TAGS)){
    if(!cats[def.cat])cats[def.cat]=[];
    cats[def.cat].push({ko,def});
  }
  let html='';
  for(const[cat,items]of Object.entries(cats)){
    html+=`<div class="tag-cat">${cat}</div><table class="tag-table"><tr><th>한글</th><th>HTML</th><th>예시</th></tr>`;
    items.forEach(({ko,def})=>{
      const ex=def.self?`&lt;${ko}&gt;`:`&lt;${ko}&gt;내용`;
      html+=`<tr><td><code>${ko}</code></td><td>&lt;${def.tag}&gt;</td><td style="color:var(--muted)">${ex}</td></tr>`;
    });
    html+='</table>';
  }
  // 스타일 속성
  html+=`<div class="tag-cat">색상/스타일 속성 [속성=값]</div><table class="tag-table"><tr><th>한글 속성</th><th>설명</th><th>예시</th></tr>`;
  const styleEx=[['색','글자 색','[색=빨강]'],['배경','배경 색','[배경=하늘]'],['크기','글자 크기','[크기=20]'],['정렬','정렬','[정렬=가운데]'],['여백','안쪽 여백','[여백=12]'],['둥글기','모서리 둥글기','[둥글기=8]'],['테두리','테두리','[테두리=1px solid]']];
  styleEx.forEach(([k,d,e])=>html+=`<tr><td><code>${k}</code></td><td style="color:var(--muted)">${d}</td><td><code>${e}</code></td></tr>`);
  html+='</table>';
  // 인라인
  html+=`<div class="tag-cat">문단 안 인라인 문법</div><table class="tag-table"><tr><th>문법</th><th>결과</th></tr><tr><td><code>**글자**</code></td><td>굵게</td></tr><tr><td><code>*글자*</code></td><td>기울임</td></tr><tr><td><code>__글자__</code></td><td>밑줄</td></tr></table>`;
  // 색상 목록
  html+=`<div class="tag-cat">사용 가능한 색상</div><div style="font-size:13px;color:var(--muted);padding:0 10px;line-height:2">${Object.keys(COLORS).join(', ')}</div>`;
  document.getElementById('tag-list').innerHTML=html;
}

let tT;
function toast(msg){const el=document.getElementById('toast');el.textContent=msg;el.classList.add('show');clearTimeout(tT);tT=setTimeout(()=>el.classList.remove('show'),2500);}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeHelp();});

// 시작 시 예제 로드
loadExample();
</script>
